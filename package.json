{
  "name": "ai-ide-desktop",
  "version": "1.0.2",
  "description": "AI Workspace – Desktop",
  "main": "main.js",
  "scripts": {
    "start": "node start.js",
    "dev": "node start.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "playwright-core": "^1.60.0"
  },
  "build": {
    "appId": "com.aiide.studio",
    "productName": "AI Workspace",
    "files": [
      "main.js",
      "start.js",
      "tab-manager.js",
      "mcp-server.js",
      "mesh-manager.js",
      "preload.js",
      "preload-connect.js",
      "preload-tab.js",
      "connect.html",
      "visual-edit/**",
      "assets/**"
    ],
    "protocols": [
      {
        "name": "AI Workspace",
        "schemes": [
          "aiide"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico",
      "extraResources": [
        {
          "from": "vendor/tailscale/win/${arch}",
          "to": "tailscale"
        }
      ]
    },
    "nsis": {
      "include": "build/installer.nsh",
      "perMachine": true,
      "allowElevation": true,
      "artifactName": "AI-Workspace-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.developer-tools",
      "extraResources": [
        {
          "from": "vendor/tailscale/mac/${arch}",
          "to": "tailscale"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Development",
      "extraResources": [
        {
          "from": "vendor/tailscale/linux/${arch}",
          "to": "tailscale"
        }
      ]
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/mcp": "^0.0.75"
  }
}
